{
  "name": "markwiemer.com",
  "private": "true",
  "type": "module",
  "scripts": {
    "//todo": "use eslint-plugin-package-json",
    "astro": "astro --config config/astro.config.mjs",
    "build": "astro build --config config/astro.config.mjs",
    "dev": "astro dev --config config/astro.config.mjs",
    "dev:e2e": "bun run dev --port 8910",
    "e2e:ci": "bun run build && bun run e2e:install && bun run e2e",
    "e2e:install": "bunx playwright install --with-deps chromium",
    "e2e": "start-server-and-test \"bun run preview:e2e\" http-get://localhost:8910 \"bun run playwright\"",
    "playwright": "playwright test --config config/playwright.config.ts",
    "playwright//": "To be used as part of `e2e`",
    "preview": "astro preview --config config/astro.config.mjs",
    "preview:e2e": "bun run preview --port 8910",
    "test": "vitest --config config/vitest.config.js",
    "test:ci": "bun run test --run",
    "trigger-deploy": "bash ../../scripts/trigger-markwiemer-deploy.sh",
    "optimize-images": "bun scripts/optimize-images.js",
    "optimize-images:dry": "bun scripts/optimize-images.js --dry-run",
    "validate:ci": "bun run test:ci && bun run e2e:ci",
    "validate:fix": "sort-package-json"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "astro": "^5.16.10",
    "sharp": "^0.34.5",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "start-server-and-test": "^3.0.0",
    "@axe-core/playwright": "^4.11.1"
  }
}
