---
import Nav from "@/components/Nav.astro";
const style = "/styles.css";
interface Props {
  pageTitle: string;
  /** Optional CSS class to apply to the main container */
  klass?: string;
}
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content="Mark Wiemer" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.webp" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.webp" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.webp" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Copied from --body-bg-X in src/public/styles.css -->
    <!-- Styles browser UI around the site -->
    <meta name="theme-color" content="white" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="black" media="(prefers-color-scheme: dark)" />

    <link rel="stylesheet" href={style} />
    <script is:inline data-notes="apply saved theme before paint">
      (() => {
        const theme = localStorage.getItem("theme");
        if (theme === "light" || theme === "dark") {
          document.documentElement.setAttribute("data-theme", theme);
        }
      })();
    </script>
    <title>{Astro.props.pageTitle} - markwiemer.com</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Nav />
    <article class={Astro.props.klass || undefined}>
      <main id="main-content">
        <slot />
      </main>
    </article>
    <script is:inline data-notes="make external links open in new tab">
      (() => {
        const processLinks = () => {
          const anchors = document.querySelectorAll("a[href]");
          for (const a of anchors) {
            const href = a.getAttribute("href");
            if (!href) continue;
            // opt-out if requested
            if (a.getAttribute("data-external-target-ignore") === "true") continue;
            // skip non-navigational or same-page links
            if (
              href.startsWith("#") ||
              href.startsWith("mailto:") ||
              href.startsWith("tel:") ||
              href.startsWith("javascript:")
            )
              continue;
            let url;
            try {
              url = new URL(href, document.baseURI);
            } catch (e) {
              continue;
            }
            // Only modify links that go to a different origin
            if (url.origin !== window.location.origin) {
              if (!a.hasAttribute("target")) a.setAttribute("target", "_blank");
              const rel = (a.getAttribute("rel") || "").split(" ").filter(Boolean);
              if (!rel.includes("noopener")) rel.push("noopener");
              if (!rel.includes("noreferrer")) rel.push("noreferrer");
              a.setAttribute("rel", rel.join(" "));
            }
          }
        };
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", processLinks, { once: true });
        } else {
          processLinks();
        }
      })();
    </script>
    <script is:inline data-notes="prevent Space key from scrolling on skip link">
      // we intentionally only apply this to the skip link
      // Space **should** scroll the page for all other links
      (() => {
        const skipLink = document.querySelector(".skip-link");
        if (skipLink) {
          skipLink.addEventListener("keydown", (e) => {
            if (e.key === " " || e.key === "Spacebar") {
              e.preventDefault();
              skipLink.click();
            }
          });
        }
      })();
    </script>
    <script is:inline data-notes="register service worker for PWA support">
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js").catch(() => {});
      }
    </script>
  </body>
</html>
