---
import Layout from "@/layouts/Layout.astro";
import BlogPostList from "@/components/BlogPostList.astro";
---

<Layout pageTitle="Blog">
  <h1>Blog</h1>
  <p>
    I used to post exclusively on <a href="https://markwiemer.medium.com">markwiemer.medium.com</a>,
    but I've copied all posts onto this site as well. Some of the newest posts are only available
    here, but I plan to <a href="https://github.com/mark-wiemer/hello-hello/issues/17">
      sync them with Medium</a
    > eventually.
  </p>
  <BlogPostList />
  <p>See also <a href="/">Home - markwiemer.com</a></p>
</Layout>

{
  /*
To see when a Medium post was made:
1. Edit story
1. View revision history
1. Monitor network logs
1. Open "first published" revision
1. Find revision index in URL
1. Find revision date from previous requests
1. Convert to ISO-8601: https://www.epochconverter.com/
*/
}
