---
import Layout from "@/layouts/Layout.astro";
import CustomDate from "@/components/CustomDate.astro";
import { getAllBlogPosts } from "@/utils/blog";

/**
 * Magic function used by Astro.
 * https://docs.astro.build/en/guides/routing/#dynamic-routes
 */
export const getStaticPaths = getAllBlogPosts;

const { module } = Astro.props;
let { default: Content, frontmatter } = module;
frontmatter ??= {};
/* todo handle "originally posted on Medium.com" stuff */
const { postTitle, postDate, postTime, lastUpdated, postType } = frontmatter;

const notesDisclaimer =
  postType === "notes"
    ? " These are personal notes, subject to change. None of this is legal advice."
    : "";
---

<Layout pageTitle={postTitle}>
  <h1>{postTitle}</h1>
  <p>
    <CustomDate date={postDate} />{postTime ? `, ${postTime}.` : "."}
    {lastUpdated ? <>{" "}Last updated <CustomDate date={lastUpdated} />.</> : ""}
    {notesDisclaimer}
  </p>
  <Content />
  <hr /><hr />
  <p>See also <a href="/blog">Blog - markwiemer.com</a></p>
</Layout>
