---
import Layout from "@/layouts/Layout.astro";
import CustomDate from "@/components/CustomDate.astro";
import { getCollection, render } from 'astro:content';

/**
 * `getStaticPaths` is a magic function used by Astro.
 * https://docs.astro.build/en/guides/routing/#dynamic-routes
 */
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    // `slug` matches the filename, `[slug].astro`
    params: { slug: post.id},
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await render(post);
const { postTitle, postDate, postTime, lastUpdated, postType } = post.data;

const notesDisclaimer =
  postType === "notes"
    ? " These are personal notes, subject to change. None of this is legal advice."
    : "";
---

<Layout pageTitle={postTitle}>
  <h1>{postTitle}</h1>
  <p>
    <CustomDate date={postDate} />{postTime ? `, ${postTime}.` : "."}
    {
      lastUpdated ? (
        <>
          {" "}
          Last updated <CustomDate date={lastUpdated} />.
        </>
      ) : (
        ""
      )
    }
    {notesDisclaimer}
  </p>
  <Content />
  <hr /><hr />
  <p>See also <a href="/blog">Blog - markwiemer.com</a></p>
</Layout>
