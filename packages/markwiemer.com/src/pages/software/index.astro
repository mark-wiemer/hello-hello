---
import Layout from "@/layouts/Layout.astro";

/*
We're using the lens "parts of a system" not "actions to manage a system"
Parts are a bit easier to think about. Actions usually act on parts anyway, not the whole.

- Focus on nouns, not verbs
*/

//#region Modern app data
const modernAppTopSections = [
  {
    className: "editor",
    title: "Editor/IDE",
    items: [
      "Operating systems",
      "Shells + terminals",
      "Coding agents",
      "Extensions",
      "Team vs personal configs",
    ],
  },
  {
    className: "frontends",
    title: "Frontends",
    items: ["Endless frameworks", "Web, mobile, desktop", "UX design"],
  },
  {
    className: "backends",
    title: "Backends",
    items: ["More endless frameworks", "Storage", "Auth", "Async compute"],
  },
  {
    className: "env",
    title: "Env",
    items: ["Secrets", "Non-source-controllable assets"],
  },
  {
    className: "observability",
    title: "Observability",
    items: ["Telemetry", "Alerting"],
  },
  {
    className: "deploy",
    title: "Deployment",
    items: ["Test environments", "Infrastructure as code", "Automated CI/CD", "Automated recovery"],
  },
];

const modernAppBottomSections = [
  {
    className: "docs",
    title: "Documentation",
    items: ["Code comments", "Markdown files", "Wiki site", "On-call runbooks"],
  },
  {
    className: "maintenance",
    title: "Maintenance",
    items: ["Project management", "Test coverage validation", "Perennial innovations"],
  },
  {
    className: "comms",
    title: "Communication",
    items: [
      "Early feedback",
      "Announcements and blogs",
      "External contributor collaboration",
      "User support",
    ],
  },
  {
    className: "agents",
    title: "Agents + AI",
    items: [
      "Integrations",
      "Security",
      "Hallucinations",
      "Costs (financial, reputational, ecological)",
    ],
  },
];
//#endregion
---

<Layout pageTitle="Software" klass="chart">
  <h1>Software</h1>
  <div class="article">
    <p>I spend a lot of time on software, below are some of my current priorities 🤓</p>
  </div>
  <!-- todo we need to add automated tests! -->
  <h2>A modern app</h2>
  <div class="article">
    <p>
      Even a single app is crazy complex, but we can manage it if we have names for its parts. Here's 
      my mental map for each of my projects. This map was heavily inspired by a secret presentation from <a
        href="https://safia.rocks/">Safia Abdalla</a
      > :) For best results, use a wide screen (1280px+).
    </p>
  </div>
  <div class="top-grid">
    {
      modernAppTopSections.map((section) => (
        <section class={`card ${section.className}`}>
          <h3>{section.title}</h3>
          <ul>
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
  <div class="bottom-grid">
    {
      modernAppBottomSections.map((section) => (
        <section class={`card ${section.className}`}>
          <h3>{section.title}</h3>
          <ul>
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
  <h2>Luanti</h2>
  <div class="article">
    <p><a href="/software/luanti">Luanti</a> is an open-source "<a href="/glossary#boxel">boxel</a>" game creation system including a game engine, distribution site, and application for players. I'm currently working on <a href="https://github.com/luanti-org/docs.luanti.org/issues/296">rewriting Luanti's documentation</a> into a domain-specific language so that we can better maintain improvements and translate the docs from Lua to TypeScript and beyond.</p>
  </div>
  <h2>Mocha</h2>
  <div class="article">
    <p>
      <a href="/software/mocha">Mocha</a> is the classic, reliable, trusted test framework for Node.js
      and the browser that was created in 2011. I've been a maintainer since August 2025, so I'm certainly
      no expert yet, but I've used Mocha significantly for testing <a href="https://ahkpp.com"
        >AHK++</a
      >, a VS Code extension that provides language support for a niche programming language.
    </p>
  </div>
</Layout>

<style>
  :root {
    --grid-gap: 20px;
    --row-min: 160px;
  }

  h2 {
    text-align: center;
  }

  .top-grid,
  .bottom-grid {
    display: grid;
    gap: var(--grid-gap);
    align-items: stretch;
    margin: 0 auto var(--grid-gap);
    max-width: 1280px;
  }

  /* 4 columns: Editor | Front/Back | Env/Observe | Deploy */
  .top-grid {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, minmax(var(--row-min), auto));
  }

  /* 3 columns: Docs | Maintenance | Comms, then Agents full-width */
  .bottom-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .card {
    box-sizing: border-box;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 1rem;
  }

  .card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .card ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  /* Top grid: explicit placement */
  .editor {
    grid-column: 1;
    grid-row: 1 / 3;
  }
  .frontends {
    grid-column: 2;
    grid-row: 1;
  }
  .backends {
    grid-column: 2;
    grid-row: 2;
  }
  .env {
    grid-column: 3;
    grid-row: 1;
  }
  .observability {
    grid-column: 3;
    grid-row: 2;
  }
  .deploy {
    grid-column: 4;
    grid-row: 1 / 3;
  }

  /* Bottom grid: agents spans all 3 columns */
  .agents {
    grid-column: 1 / -1;
  }

  @media (max-width: 1280px) {
    .top-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: none;
    }

    /* reset explicit placement so auto-placement takes over */
    .editor,
    .frontends,
    .backends,
    .env,
    .observability,
    .deploy {
      grid-column: unset;
      grid-row: unset;
    }

    .bottom-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .comms {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .top-grid,
    .bottom-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
