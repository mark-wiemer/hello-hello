const toId = (term: string): string => {
  return term
    .toLowerCase()
    .replaceAll(/[ (.]/g, "-")
    .replaceAll(/[:")]/g, "")
    .replaceAll(/-+/g, "-");
};
---

<Layout pageTitle="Glossary">
  <h1>Glossary</h1>
  <p>
    Words are hard. A glossary, even for a small project, greatly reduces <a href="#cognitive-load"
      >cognitive load</a
    > and makes work easier. I started this practice after reading Domain-Driven Design by Eric Evans,
    who coined the term <a href="#ubiquitous-language">ubiquitous language</a>. These definitions
    are not perfect and are subject to change :)
  </p>

  <dl>
    {
      glossary.map((termDef) => (
        <>
          <dt id={toId(termDef[0])}>{termDef[0]}</dt>
          <dd>
            {/* https://github.com/mark-wiemer/hello-hello/issues/130 */}
            {/* lookahead to ensure there is not a digit immediately after the slash */}
            {termDef[1].split(/(?<=\/)(?!\d)/).map((part: string, i: number) => {
              const shouldAddWbr = i > 0;
              return (
                <>
                  {shouldAddWbr && <wbr />}
                  {part}
                </>
              );
            })}
          </dd>
        </>
      ))
    }
  </dl>
</Layout>
