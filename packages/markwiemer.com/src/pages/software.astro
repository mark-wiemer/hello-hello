---
import Layout from "@/layouts/Layout.astro";

const sections = [
  {
    className: "editor",
    title: "Editor/IDE",
    items: ["Operating systems", "Shells + terminals", "Coding agents", "Extensions"],
  },
  {
    className: "frontends",
    title: "Frontends",
    items: ["Endless frameworks", "Web, mobile, desktop", "UX design"],
  },
  {
    className: "services",
    title: "Services",
    items: ["Storage", "Auth", "Async compute"],
  },
  {
    className: "agents",
    title: "Agents + AI",
    items: [
      "(Missing) integrations",
      "Security",
      "Hallucinations",
      "Costs (financial, reputational, ecological)",
    ],
  },
  {
    className: "env",
    title: "Env",
    items: ["Managing secrets", "Non-source-controllable assets"],
  },
  {
    className: "backends",
    title: "Backends",
    items: ["More endless frameworks"],
  },
  {
    className: "observability",
    title: "Observability",
    items: ["OpenTelemetry", "Alerting"],
  },
  {
    className: "manifests",
    title: "Manifests + Scripts",
    items: [
      "Manifest languages (YAML, JSON, Dockerfiles)",
      "Hard-to-read scripts (Bash, pwsh)",
      'README.md, internal wikis, "tribal knowledge"',
    ],
  },
  {
    className: "deploy",
    title: "Deployment handoff",
    items: ["Manual deployments", "Automated CI/CD", "Enterprise devops workflow"],
  },
];
---

<Layout pageTitle="Software" klass="chart">
  <h1>A modern app</h1>
  <p>
    Software is crazy, but we can manage it if we have names for the things we're building. Here's
    my mental map for all projects.
  </p>
  <p>
    This map was heavily inspired by a secret presentation from <a href="https://safia.rocks/"
      >Safia Abdalla</a
    > :)
  </p>
  <!-- todo we need to add automated tests! -->
  <p>This page is very new, for best results, use a wide screen (1280px+)</p>
  <div class="grid">
    {
      sections.map((section) => (
        <section class={`card ${section.className}`}>
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Layout>

<style>
  .grid {
    --card-min-width: 220px;
    --grid-gap: 20px;
    --row-min: 160px;
    --grid-columns: 5;
    display: grid;
    gap: var(--grid-gap);
    grid-template-columns: repeat(var(--grid-columns), minmax(var(--card-min-width), 1fr));
    grid-template-rows: repeat(3, minmax(var(--row-min), auto));
    align-items: stretch;

    @media (max-width: 1280px) {
      --grid-columns: 2;
    }
  }

  .card {
    box-sizing: border-box;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 1rem;
  }

  .card h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .card ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .editor,
  .services,
  .env {
    grid-row: span 2;
  }

  .manifests {
    grid-column: span 3;
  }

  .deploy {
    grid-column: span 2;
  }

  @media (max-width: 640px) {
    .grid {
      --grid-columns: 1;
    }

    .manifests,
    .deploy {
      grid-column: span 1;
    }
  }
</style>
