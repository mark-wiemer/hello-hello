---
import Layout from "@/layouts/Layout.astro";

/*
We're using the lens "parts of a system" not "actions to manage a system"
Parts are a bit easier to think about. Actions usually act on parts anyway, not the whole.

- Focus on nouns, not verbs
*/

const topSections = [
  {
    className: "editor",
    title: "Editor/IDE",
    items: [
      "Operating systems",
      "Shells + terminals",
      "Coding agents",
      "Extensions",
      "Team vs personal configs",
    ],
  },
  {
    className: "frontends",
    title: "Frontends",
    items: ["Endless frameworks", "Web, mobile, desktop", "UX design"],
  },
  {
    className: "backends",
    title: "Backends",
    items: ["More endless frameworks", "Storage", "Auth", "Async compute"],
  },
  {
    className: "env",
    title: "Env",
    items: ["Secrets", "Non-source-controllable assets"],
  },
  {
    className: "observability",
    title: "Observability",
    items: ["OpenTelemetry", "Alerting"],
  },
  {
    className: "deploy",
    title: "Deployment",
    items: ["Test environments", "Infrastructure as code", "Automated CI/CD", "Automated recovery"],
  },
];

const bottomSections = [
  {
    className: "docs",
    title: "Documentation",
    items: ["Code comments", "Markdown files", "Wiki site", "On-call runbooks"],
  },
  {
    className: "maintenance",
    title: "Maintenance",
    items: ["Project management", "Test coverage validation", "Perennial innovations"],
  },
  {
    className: "comms",
    title: "Communications",
    items: ["Announcements and blogs", "External contributor collaboration", "User support"],
  },
  {
    className: "agents",
    title: "Agents + AI",
    items: [
      "Integrations",
      "Security",
      "Hallucinations",
      "Costs (financial, reputational, ecological)",
    ],
  },
];
---

<Layout pageTitle="Software" klass="chart">
  <h1>Software</h1>
  <!-- todo we need to add automated tests! -->
  <p>
    Software is crazy, but we can manage it if we have names for the things we're building. Here's
    my mental map for all projects. This map was heavily inspired by a secret presentation from <a
      href="https://safia.rocks/">Safia Abdalla</a
    > :) For best results, use a wide screen (1280px+).
  </p>
  <h2>A modern app</h2>
  <div class="top-grid">
    {
      topSections.map((section) => (
        <section class={`card ${section.className}`}>
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
  <div class="bottom-grid">
    {
      bottomSections.map((section) => (
        <section class={`card ${section.className}`}>
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Layout>

<style>
  :root {
    --grid-gap: 20px;
    --row-min: 160px;
  }

  .top-grid,
  .bottom-grid {
    display: grid;
    gap: var(--grid-gap);
    align-items: stretch;
    margin-bottom: var(--grid-gap);
  }

  /* 4 columns: Editor | Front/Back | Env/Observe | Deploy */
  .top-grid {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, minmax(var(--row-min), auto));
  }

  /* 3 columns: Docs | Maintenance | Comms, then Agents full-width */
  .bottom-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .card {
    box-sizing: border-box;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 1rem;
  }

  .card h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .card ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  /* Top grid: explicit placement */
  .editor {
    grid-column: 1;
    grid-row: 1 / 3;
  }
  .frontends {
    grid-column: 2;
    grid-row: 1;
  }
  .backends {
    grid-column: 2;
    grid-row: 2;
  }
  .env {
    grid-column: 3;
    grid-row: 1;
  }
  .observability {
    grid-column: 3;
    grid-row: 2;
  }
  .deploy {
    grid-column: 4;
    grid-row: 1 / 3;
  }

  /* Bottom grid: agents spans all 3 columns */
  .agents {
    grid-column: 1 / -1;
  }

  @media (max-width: 1280px) {
    .top-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: none;
    }

    /* reset explicit placement so auto-placement takes over */
    .editor,
    .frontends,
    .backends,
    .env,
    .observability,
    .deploy {
      grid-column: unset;
      grid-row: unset;
    }

    .bottom-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .comms {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .top-grid,
    .bottom-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
