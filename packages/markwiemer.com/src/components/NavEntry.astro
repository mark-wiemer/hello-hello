---
interface Props {
  href: string;
  text: string;
  /** Opens the link in a new tab if true. Defaults to false, opening in same tab. */
  newTab?: boolean;
}
const { href, text, newTab } = Astro.props;
let currentPath = Astro.url.pathname;
if (currentPath.endsWith("/")) {
  currentPath = currentPath.slice(0, -1);
}
---

{
  currentPath === href || (currentPath.length < 2 && href === "/") ? (
    <li>{text}</li>
  ) : (
    <li>
      <a href={href} data-external-target-ignore={!newTab}>
        {text}
      </a>
    </li>
  )
}
