---
interface Props {
  href: string;
  text: string;
}
const { href, text } = Astro.props;
let currentPath = Astro.url.pathname;
if (currentPath.endsWith("/")) {
  currentPath = currentPath.slice(0, -1);
}
---

{
  currentPath === href || (currentPath.length < 2 && href === "/") ? (
    <li>{text}</li>
  ) : (
    <li>
      <a href={href}>{text}</a>
    </li>
  )
}
