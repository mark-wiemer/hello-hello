---
import { getAllBlogPosts, sortBlogPostsOldestFirst } from "@/utils/blog";
import CustomDate from "@/components/CustomDate.astro";

type PostListItem = ReturnType<typeof getAllBlogPosts>[0]["props"]["module"]["frontmatter"] & {
  slug: string;
};

interface Props {
  filter?: (post: PostListItem) => boolean;
  limit?: number;
}

const { filter, limit } = Astro.props;

let posts: PostListItem[] = getAllBlogPosts()
  .map<PostListItem>(({ params, props }) => {
    const listed = props.module?.frontmatter.listed ?? true;
    return { ...props.module?.frontmatter, slug: params.slug, listed };
  })
  .filter((post) => post.postDate && post.slug && post.listed)
  .sort(sortBlogPostsOldestFirst)
  .reverse()
  .filter(filter ?? (() => true))
  .slice(0, limit ?? undefined);
---

<!-- prettier-ignore -->
<ul>
  {
    posts.map((post) => (
      <li>
        <CustomDate date={post.postDate} />{post.postType === "notes" ? " (notes): " : ": "}<a href={`/blog/${post.slug}`}>{post.postTitle}</a>
        {post.lastUpdated ? (
          <>
            {" "}
            (last updated <CustomDate date={post.lastUpdated} />)
          </>
        ) : (
          ""
        )}
      </li>
    ))
  }
</ul>
