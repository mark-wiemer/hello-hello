---
import { oldestFirst } from "@/utils/date";
import CustomDate from "@/components/CustomDate.astro";
import { getCollection, type InferEntrySchema } from 'astro:content';

type PostListItem = InferEntrySchema<"blog"> & {
  slug: string;
};

interface Props {
  filter?: (post: PostListItem) => boolean;
  limit?: number;
}

const { filter, limit } = Astro.props;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    // `slug` matches the filename, `[slug].astro`
    params: { slug: post.id},
    props: { post },
  }));
};

const posts = (await getCollection('blog'))
  .map<PostListItem>(entry => {
    const data = entry.data;
    const listed = data.listed ?? true;
    return { ...data, slug: entry.id, listed };
  })
  .filter((post) => post.postDate && post.slug && post.listed)
  .sort(oldestFirst)
  .reverse()
  .filter(filter ?? (() => true))
  .slice(0, limit ?? undefined);
---

<!-- prettier-ignore -->
<ul aria-label="Blog posts">
  {
    posts.map((post) => (
      <li>
        <CustomDate date={post.postDate} />{post.postType === "notes" ? " (notes): " : ": "}<a href={`/blog/${post.slug}`}>{post.postTitle}</a>
        {post.lastUpdated ? (
          <>
            {" "}
            (last updated <CustomDate date={post.lastUpdated} />)
          </>
        ) : (
          ""
        )}
      </li>
    ))
  }
</ul>
