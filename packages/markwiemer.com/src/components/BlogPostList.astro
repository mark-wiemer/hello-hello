---
import { getAllBlogPosts } from "@/utils/blog";

type PostListItem = {
  postDate: string;
  postTime: string | undefined;
  postTitle: string;
  postType: string;
  lastUpdated: string | undefined;
  /** Whether to list the post in the index and home page */
  listed: boolean;
  slug: string;
};

interface Props {
  filter?: (post: PostListItem) => boolean;
  limit?: number;
}

const { filter, limit } = Astro.props;

let posts: PostListItem[] = getAllBlogPosts()
  .map<PostListItem>(({ params, props }) => {
    const listed = props.module?.frontmatter.listed ?? true;
    return { ...props.module?.frontmatter, slug: params.slug, listed };
  })
  .filter((post) => post.postDate && post.slug && post.listed)
  .sort((a, b) => b.postDate.localeCompare(a.postDate))
  .filter(filter ?? (() => true))
  .slice(0, limit ?? undefined);
---

<ul>
  {
    posts.map((post) => (
      <li>
        {post.postType === "notes" ? `${post.postDate} (notes): ` : `${post.postDate}: `}
        <a href={`/blog/${post.slug}`}>{post.postTitle}</a>
        {post.lastUpdated ? ` (last updated ${post.lastUpdated})` : ""}
      </li>
    ))
  }
</ul>
