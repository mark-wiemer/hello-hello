---
import NavEntry from "@/components/NavEntry.astro";
---

{/* prettier-ignore */}
<button id="toggleMenu" aria-label="Menu">☰</button>
<div id="siteMenu" aria-expanded="false" inert>
  <nav>
    <h2>Here</h2>
    <ul aria-label="Sitemap">
      <NavEntry href="/" text="Home" />
      <NavEntry href="/blog/who-am-i" text="About" />
      <NavEntry href="/blog" text="Blog" />
      <NavEntry href="/games" text="Games" />
      <NavEntry href="/glossary" text="Glossary" />
      <NavEntry href="/misc" text="Miscellaneous" />
      <NavEntry href="/resume" text="Resume" />
      <NavEntry href="/software" text="Software" />
    </ul>
    <h2>Elsewhere</h2>
    <ul aria-label="External links">
      <NavEntry href="https://ahkpp.com" text="AHK++" />
      <NavEntry href="https://mochajs.org" text="Mocha" />
      <!-- invisible char U+00a0 is non-breaking space -->
      <!-- https://en.wikipedia.org/wiki/Non-breaking_space -->
      <NavEntry
        href="https://github.com/mark-wiemer/hello-hello/tree/main/packages/markwiemer.com"
        text="Website source"
      />
    </ul>
    <script is:inline data-notes="handle nav toggle">
      const toggleButton = document.querySelector("#toggleMenu");
      const siteMenu = document.querySelector("#siteMenu");
      toggleButton?.addEventListener("click", () => {
        if (siteMenu.getAttribute("aria-expanded") === "true") {
          siteMenu.setAttribute("aria-expanded", "false");
          siteMenu.setAttribute("inert", "");
          document.body.classList.remove("nav-open");
          return;
        } else {
          siteMenu.setAttribute("aria-expanded", "true");
          siteMenu.removeAttribute("inert");
          document.body.classList.add("nav-open");
        }
      });
    </script>
  </nav>
  <h2>Settings</h2>
  <button id="themeToggle" class="toggle" aria-live="polite">Error</button>
  <script is:inline data-notes="handle theme toggle">
    (() => {
      const themeToggle = document.querySelector("#themeToggle");
      const themes = ["system", "light", "dark"];
      const labels = { system: "System", light: "Light", dark: "Dark" };

      const getStoredTheme = () => localStorage.getItem("theme") || "system";

      const applyTheme = (theme) => {
        if (theme === "system") {
          document.documentElement.removeAttribute("data-theme");
        } else {
          document.documentElement.setAttribute("data-theme", theme);
        }
      };

      const updateButton = (theme) => {
        if (themeToggle) themeToggle.textContent = `Theme: ${labels[theme]}`;
      };

      // Initialize button text from current state
      const current = getStoredTheme();
      updateButton(current);

      themeToggle?.addEventListener("click", () => {
        const current = getStoredTheme();
        const nextIndex = (themes.indexOf(current) + 1) % themes.length;
        const next = themes[nextIndex];
        if (next === "system") {
          localStorage.removeItem("theme");
        } else {
          localStorage.setItem("theme", next);
        }
        applyTheme(next);
        updateButton(next);
      });
    })();
  </script>

  <button id="datetimeFormatToggle" class="toggle" aria-live="polite">Error</button>
  <script is:inline data-notes="handle date format toggle">
    (() => {
      const datetimeFormatToggle = document.querySelector("#datetimeFormatToggle");
      const formats = ["system", "iso"];
      const labels = { system: "System", iso: "ISO" };

      const getStoredFormat = () => localStorage.getItem("dateFormat") || "system";

      const updateButton = (format) => {
        if (datetimeFormatToggle) datetimeFormatToggle.textContent = `Dates: ${labels[format]}`;
      };

      // Initialize button text from current state
      const current = getStoredFormat();
      updateButton(current);

      datetimeFormatToggle?.addEventListener("click", () => {
        const current = getStoredFormat();
        const nextIndex = (formats.indexOf(current) + 1) % formats.length;
        const next = formats[nextIndex];
        if (next === "system") {
          localStorage.removeItem("dateFormat");
        } else {
          localStorage.setItem("dateFormat", next);
        }
        updateButton(next);
        window.dispatchEvent(new Event("dateformat-changed"));
      });
    })();
  </script>
</div>
