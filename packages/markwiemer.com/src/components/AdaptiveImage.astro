---
import { Image } from "astro:assets";
import { getImage } from "astro:assets";

interface Props {
  alt: string;
  src: ImageMetadata;
  thumbnailSrc: ImageMetadata;
  class?: string;
}

const { alt, src, thumbnailSrc, class: className } = Astro.props;

// Pre-process the full-size image to get optimized URL (WebP conversion, etc.)
const optimizedFull = await getImage({ src });
---

<div class="adaptive-image-wrapper" data-full-src={optimizedFull.src}>
  <Image
    alt={alt}
    src={thumbnailSrc}
    class={`adaptive-image ${className || ""}`}
    loading="lazy"
  />
</div>

<!-- todo dedupe this script -->
<script is:inline data-notes="shouldLoadHighRes">
  console.debug("[AdaptiveImage] Client script loaded...");
  // test changes with a new tab, not just refreshing
  // todo add user config to toggle this feature if they want
  function shouldLoadHighRes() {
    if (!("connection" in navigator)) {
      return false;
    }
    const connection = navigator.connection;
    const effectiveType = connection.effectiveType;
    const saveData = connection.saveData;
    const downlink = connection.downlink;

    if (saveData) {
      return false;
    }

    // downlink is megabits per second, but usually not provided to avoid fingerprinting
    console.debug("[AdaptiveImage] Connection info:", { effectiveType, saveData, downlink });
    return effectiveType === "4g";
  }

  function tryLoadHighRes() {
    console.debug("[AdaptiveImage] Attempting to load high-res images...");
    if (!shouldLoadHighRes()) {
      return;
    }

    console.debug("[AdaptiveImage] Conditions met, loading high-res images...");
    const wrappers = document.querySelectorAll(".adaptive-image-wrapper[data-full-src]");
    wrappers.forEach((wrapper) => {
      const fullSrc = wrapper.getAttribute("data-full-src");
      if (!fullSrc || !(wrapper instanceof HTMLElement)) return;

      // Remove attribute immediately to prevent double-loading on repeated calls
      wrapper.removeAttribute("data-full-src");

      // Preload the high-res image
      const link = document.createElement("link");
      link.rel = "preload";
      link.as = "image";
      link.href = fullSrc;
      document.head.appendChild(link);

      // Create a high-res overlay image that fades in on top of the thumbnail.
      // This avoids flicker: the thumbnail stays visible while the high-res loads.
      const thumbnailImg = wrapper.querySelector("img");
      const fullImg = new Image();
      fullImg.className = "adaptive-image-full";
      if (thumbnailImg) {
        fullImg.alt = thumbnailImg.alt;
      }
      fullImg.onload = () => {
        fullImg.classList.add("loaded");
      };
      fullImg.onerror = () => {
        console.error("[AdaptiveImage] Failed to load high-res image:", fullSrc);
        fullImg.remove();
      };
      fullImg.src = fullSrc;
      wrapper.appendChild(fullImg);
    });
  }

  // Check connection on page load
  if (document.readyState === "loading") {
    console.debug("[AdaptiveImage] Document is still loading, waiting for DOMContentLoaded...");
    document.addEventListener("DOMContentLoaded", tryLoadHighRes);
  } else {
    console.debug("[AdaptiveImage] Document already loaded, checking connection immediately...");
    tryLoadHighRes();
  }

  // Also listen for connection changes
  if ("connection" in navigator) {
    console.debug("[AdaptiveImage] Adding event listener for connection changes...");
    navigator.connection.addEventListener("change", () => {
      tryLoadHighRes();
    });
  }
</script>
