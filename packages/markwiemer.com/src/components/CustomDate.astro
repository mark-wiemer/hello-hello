---
interface Props {
  date: string;
}

const { date } = Astro.props;
---

<time datetime={date} class="custom-date">{date}</time>

<script>
  document.querySelectorAll("time.custom-date").forEach((el) => {
    const isoDate = el.getAttribute("datetime");
    if (!isoDate) return;
    // Parse as local date to avoid timezone offset issues
    const date = new Date(isoDate + "T00:00:00");
    // For now, use yyyy-mm-dd for consistency.
    // To support user-specific date formatting, replace with:
    // el.textContent = date.toLocaleDateString();
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    el.textContent = `${year}-${month}-${day}`;
  });
</script>
