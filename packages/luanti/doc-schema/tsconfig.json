// Magic file used by tsx, esbuild, and typescript to compile TS to JS in a specific way
{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "module": "nodenext",
    "paths": {
      // should match vitest.config.ts
      "@/*": ["src/*"]
    },
    "types": ["node"]
  }
}
