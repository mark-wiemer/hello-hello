{
    "name": "hello-react",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "tsc && vite build",
        "preci": "bunx playwright install",
        "ci": "start-server-and-test start:ci http-get://localhost:8080 playwright",
        "format": "bun run format:inner -- --check .",
        "format:fix": "bun run format:inner -- --write .",
        "format:inner": "prettier",
        "lint": "bun run lint:inner && echo No ESLint problems",
        "lint:fix": "bun run lint:inner -- --fix",
        "lint:inner": "eslint --max-warnings 0",
        "packagejson": "sort-package-json --check",
        "packagejson:fix": "sort-package-json",
        "playwright": "playwright test",
        "preview": "vite preview",
        "start": "vite --open",
        "start:ci": "vite",
        "test": "vitest --run",
        "tsc": "tsc && echo No TS problems",
        "validate": "bun run packagejson && bun run format && bun run lint && bun run validate:unfixable",
        "validate:fix": "bun run packagejson:fix && bun run format:fix && bun run lint:fix && bun run validate:unfixable",
        "validate:unfixable": "bun run tsc && bun run test && bun run ci && echo Ready for review!",
        "watch": "vitest"
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.29.0",
        "@playwright/test": "^1.53.1",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^4.0.3",
        "eslint": "^9.29.0",
        "jsdom": "^26.1.0",
        "prettier": "3.5.3",
        "sort-package-json": "^3.2.1",
        "start-server-and-test": "^2.0.12",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.34.1",
        "vite": "^6.3.5",
        "vitest": "^3.2.4"
    },
    "engines": {
        "bun": "^1"
    }
}
